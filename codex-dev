#!/usr/bin/env bash
set -Eeuo pipefail

APP="codex-dev"
VERSION="0.2.2-local"
DEFAULT_FEDORA_IMAGE="registry.fedoraproject.org/fedora:latest"
CONTAINER_PREFIX="codex-dev"

expand_leading_tilde() {
  local p="$1"
  case "$p" in
    "~") printf '%s' "$HOME" ;;
    "~/"*) printf '%s/%s' "$HOME" "${p#~/}" ;;
    *) printf '%s' "$p" ;;
  esac
}

PROJECTS_ROOT="$(expand_leading_tilde "${CODEX_DEV_PROJECTS_ROOT:-$HOME/Projects}")"
CONFIG_HOME="$(expand_leading_tilde "${XDG_CONFIG_HOME:-$HOME/.config}")"
CONFIG_DIR="$(expand_leading_tilde "${CODEX_DEV_CONFIG_DIR:-$CONFIG_HOME/codex-dev}")"
BUILD_ROOT="$CONFIG_DIR/build"
IMAGE_PREFIX="${CODEX_DEV_IMAGE_PREFIX:-localhost/codex-dev}"

# The visible codex command is installed into the image here.
CODEX_INSTALL_DIR="/usr/local/bin"
CODEX_INSTALL_CACHE="/opt/codex-standalone"

log() { printf '[%s] %s\n' "$APP" "$*" >&2; }
warn() { printf '[%s] WARNING: %s\n' "$APP" "$*" >&2; }
die() { printf '[%s] ERROR: %s\n' "$APP" "$*" >&2; exit 1; }

usage() {
  cat <<USAGE
codex-dev $VERSION

Usage:
  codex-dev setup
  codex-dev init <project> [profile]
  codex-dev profiles
  codex-dev list
  codex-dev config <project>
  codex-dev edit <project>
  codex-dev edit-build-script <project>
  codex-dev build <project>
  codex-dev shell <project> [--rw-root]
  codex-dev omx <project> [--rw-root]
  codex-dev codex <project> [--rw-root] [-- <extra codex args...>]
  codex-dev exec <project> [--rw-root] -- <prompt>
  codex-dev attach <shell|omx|codex|exec> <project> [...]
  codex-dev doctor [project]
  codex-dev volumes <project>
  codex-dev reset-cache <project>
  codex-dev reset-home <project>
  codex-dev nuke-env <project>
  codex-dev uninstall
  codex-dev completion zsh [--command <absolute-path>]

Environment overrides:
  CODEX_DEV_PROJECTS_ROOT   default: ~/Projects
  CODEX_DEV_CONFIG_DIR      default: ~/.config/codex-dev
  CODEX_DEV_IMAGE_PREFIX    default: localhost/codex-dev
USAGE
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "Missing command: $1"
}

require_not_root() {
  [[ "$(id -u)" != "0" ]] || die "Do not run codex-dev as root. Use rootless Podman as your normal Fedora user."
}

trim() {
  local s="$*"
  s="${s#"${s%%[![:space:]]*}"}"
  s="${s%"${s##*[![:space:]]}"}"
  printf '%s' "$s"
}

strip_inline_comment() {
  local s="$1" out="" quote="" ch prev=""
  local i
  for ((i = 0; i < ${#s}; i++)); do
    ch="${s:i:1}"
    if [[ -z "$quote" && "$ch" == "#" ]]; then
      break
    fi
    if [[ "$ch" == "'" && "$quote" != '"' ]]; then
      if [[ "$quote" == "'" ]]; then quote=""; else quote="'"; fi
    elif [[ "$ch" == '"' && "$quote" != "'" && "$prev" != "\\" ]]; then
      if [[ "$quote" == '"' ]]; then quote=""; else quote='"'; fi
    fi
    out+="$ch"
    prev="$ch"
  done
  printf '%s' "$out"
}

strip_outer_quotes_or_die() {
  local val="$1" cfg="$2" lineno="$3"
  if [[ "${val:0:1}" == '"' ]]; then
    [[ ${#val} -ge 2 && "${val: -1}" == '"' ]] || die "Unmatched double quote in $cfg:$lineno"
    val="${val:1:${#val}-2}"
  elif [[ "${val:0:1}" == "'" ]]; then
    [[ ${#val} -ge 2 && "${val: -1}" == "'" ]] || die "Unmatched single quote in $cfg:$lineno"
    val="${val:1:${#val}-2}"
  fi
  printf '%s' "$val"
}

valid_project_name() {
  local name="$1"
  [[ "$name" =~ ^[A-Za-z0-9][A-Za-z0-9._-]{0,127}$ ]] || return 1
  [[ "$name" != *".."* ]] || return 1
  [[ "$name" != "." && "$name" != ".." ]] || return 1
}

require_project_name() {
  local name="${1:-}"
  [[ -n "$name" ]] || die "Project name is required."
  valid_project_name "$name" || die "Invalid project name '$name'. Use letters, digits, dot, underscore, hyphen; no slash or '..'."
}

validate_host_path_string() {
  local label="$1" path="$2"
  [[ -n "$path" ]] || die "$label must not be empty."
  [[ "$path" == /* ]] || die "$label must be an absolute path. Do not use a literal '~' in environment variables; use an expanded absolute path."
  [[ "$path" != *":"* ]] || die "$label must not contain ':', because Podman volume syntax uses ':'. Got: $path"
  [[ "$path" != *$'\n'* && "$path" != *$'\r'* ]] || die "$label must not contain newline characters."
}

validate_image_prefix() {
  [[ -n "$IMAGE_PREFIX" ]] || die "CODEX_DEV_IMAGE_PREFIX must not be empty."
  [[ "$IMAGE_PREFIX" != -* ]] || die "CODEX_DEV_IMAGE_PREFIX must not start with '-'."
  [[ "$IMAGE_PREFIX" != *[[:space:]]* ]] || die "CODEX_DEV_IMAGE_PREFIX must not contain whitespace."
  [[ "$IMAGE_PREFIX" =~ ^[A-Za-z0-9._:/-]+$ ]] || die "CODEX_DEV_IMAGE_PREFIX contains unsupported characters: $IMAGE_PREFIX"
}

ensure_setup_dirs() {
  validate_host_path_string "Projects root" "$PROJECTS_ROOT"
  mkdir -p "$CONFIG_DIR" "$BUILD_ROOT" "$PROJECTS_ROOT" || die "Failed to create config/build/projects directories."
}

ensure_projects_root_safe() {
  local root_real home_real forbidden
  validate_host_path_string "Projects root" "$PROJECTS_ROOT"
  [[ -d "$PROJECTS_ROOT" ]] || die "Projects root does not exist: $PROJECTS_ROOT"
  [[ ! -L "$PROJECTS_ROOT" ]] || die "Projects root must not be a symlink: $PROJECTS_ROOT"
  root_real="$(realpath -e "$PROJECTS_ROOT")" || die "Cannot resolve Projects root: $PROJECTS_ROOT"
  home_real="$(realpath -e "$HOME")" || die "Cannot resolve HOME: $HOME"

  [[ "$root_real" != "/" ]] || die "Refusing to use / as Projects root."
  [[ "$root_real" != "$home_real" ]] || die "Refusing to use HOME itself as Projects root: $root_real"
  for forbidden in /home /root /etc /usr /var /run /mnt /media /dev /proc /sys; do
    [[ "$root_real" != "$forbidden" ]] || die "Refusing unsafe Projects root: $root_real"
  done
  [[ -w "$root_real" ]] || die "Projects root is not writable: $root_real"
}

ensure_projects_root_readable_safe() {
  local root_real home_real forbidden
  validate_host_path_string "Projects root" "$PROJECTS_ROOT"
  [[ -d "$PROJECTS_ROOT" ]] || return 1
  [[ ! -L "$PROJECTS_ROOT" ]] || return 1
  root_real="$(realpath -e "$PROJECTS_ROOT" 2>/dev/null)" || return 1
  home_real="$(realpath -e "$HOME" 2>/dev/null || true)"

  [[ "$root_real" != "/" ]] || return 1
  if [[ -n "$home_real" ]]; then
    [[ "$root_real" != "$home_real" ]] || return 1
  fi
  for forbidden in /home /root /etc /usr /var /run /mnt /media /dev /proc /sys; do
    [[ "$root_real" != "$forbidden" ]] || return 1
  done
  [[ -r "$root_real" ]] || return 1
}

project_path_literal() {
  local name="$1"
  printf '%s/%s' "$PROJECTS_ROOT" "$name"
}

project_path_real() {
  local name="$1"
  local p root_real real
  p="$(project_path_literal "$name")"
  [[ -d "$p" ]] || die "Project directory does not exist: $p"
  [[ ! -L "$p" ]] || die "Project directory must not be a symlink: $p"
  root_real="$(realpath -e "$PROJECTS_ROOT")"
  real="$(realpath -e "$p")"
  [[ "$real" == "$root_real/"* ]] || die "Project escaped Projects root: $real"
  [[ "$real" != "$root_real" ]] || die "Refusing to use Projects root itself as a project."
  validate_host_path_string "Project real path" "$real"
  printf '%s' "$real"
}

project_meta_dir() {
  local name="$1"
  printf '%s/.codex-dev' "$(project_path_literal "$name")"
}

project_config_path() {
  local name="$1"
  printf '%s/project.env' "$(project_meta_dir "$name")"
}

ensure_project_meta_safe() {
  local name="$1" meta
  meta="$(project_meta_dir "$name")"
  [[ -d "$meta" ]] || die "Project metadata directory missing: $meta. Run: codex-dev init $name"
  [[ ! -L "$meta" ]] || die "Project metadata directory must not be a symlink: $meta"
}

safe_slug() {
  local s="$1"
  s="$(printf '%s' "$s" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9_.-]+/-/g; s/^[._-]+//; s/[._-]+$//')"
  [[ -n "$s" ]] || s="project"
  printf '%s' "$s"
}

resource_id() {
  local name="$1" slug hash
  slug="$(safe_slug "$name")"
  hash="$(printf '%s' "$name" | sha256sum | awk '{print substr($1,1,10)}')"
  printf '%s-%s' "$slug" "$hash"
}

profile_packages() {
  local profile="$1"
  case "$profile" in
    generic)
      cat <<'PKGS'
PKGS
      ;;
    python)
      cat <<'PKGS'
python3 python3-pip python3-devel python3-virtualenv pipx
PKGS
      ;;
    node)
      cat <<'PKGS'
nodejs npm
PKGS
      ;;
    rust)
      cat <<'PKGS'
rust cargo rustfmt
PKGS
      ;;
    go)
      cat <<'PKGS'
golang
PKGS
      ;;
    gtk)
      cat <<'PKGS'
python3 python3-pip meson ninja-build pkgconf-pkg-config gtk4-devel libadwaita-devel blueprint-compiler gettext desktop-file-utils
PKGS
      ;;
    android)
      cat <<'PKGS'
java-21-openjdk-devel gradle android-tools cmake ninja-build clang zip unzip
PKGS
      ;;
    custom)
      cat <<'PKGS'
PKGS
      ;;
    *)
      return 1
      ;;
  esac
}

profile_exists() {
  profile_packages "$1" >/dev/null 2>&1
}

print_profiles() {
  cat <<'EOF_PROFILES'
generic   基础开发工具 + Codex CLI
python    generic + Python/pip/venv/pipx
node      generic + Node.js/npm
rust      generic + Rust/Cargo
go        generic + Go
gtk       generic + GTK4/libadwaita/meson/ninja
android   generic + Java/Gradle/android-tools；Android SDK 仍建议按项目单独补充
custom    只用基础工具，额外依赖完全写 DNF_PACKAGES
EOF_PROFILES
}

profile_names() {
  printf '%s\n' generic python node rust go gtk android custom
}

public_commands() {
  cat <<'EOF_COMMANDS'
setup
init
profiles
list
config
edit
edit-build-script
build
shell
omx
codex
exec
attach
doctor
volumes
reset-cache
reset-home
nuke-env
uninstall
completion
EOF_COMMANDS
}

managed_project_names() {
  local d name meta cfg nullglob_was_set=0
  ensure_projects_root_readable_safe || return 0
  shopt -q nullglob && nullglob_was_set=1
  shopt -s nullglob
  for d in "$PROJECTS_ROOT"/*; do
    [[ -d "$d" && ! -L "$d" ]] || continue
    name="$(basename "$d")"
    valid_project_name "$name" || continue
    meta="$d/.codex-dev"
    cfg="$meta/project.env"
    [[ -d "$meta" && ! -L "$meta" ]] || continue
    [[ -f "$cfg" && ! -L "$cfg" ]] || continue
    printf '%s\n' "$name"
  done
  if [[ "$nullglob_was_set" -eq 1 ]]; then
    shopt -s nullglob
  else
    shopt -u nullglob
  fi
}

# Defaults loaded from a project's declarative config.
CFG_PROFILE="generic"
CFG_FEDORA_IMAGE="$DEFAULT_FEDORA_IMAGE"
CFG_DNF_PACKAGES=""
CFG_READ_ONLY_ROOT="yes"
CFG_BUILD_SCRIPT=""

validate_fedora_image() {
  local img="$1"
  [[ -n "$img" ]] || die "FEDORA_IMAGE must not be empty."
  [[ "$img" != -* ]] || die "FEDORA_IMAGE must not start with '-'."
  [[ "$img" != *[[:space:]]* ]] || die "FEDORA_IMAGE must not contain whitespace."
  case "$img" in
    fedora|fedora:*|registry.fedoraproject.org/fedora|registry.fedoraproject.org/fedora:*) ;;
    *) die "FEDORA_IMAGE must be a Fedora image such as registry.fedoraproject.org/fedora:latest" ;;
  esac
  [[ "$img" =~ ^[A-Za-z0-9._:/-]+$ ]] || die "FEDORA_IMAGE contains unsupported characters: $img"
}

validate_package_tokens() {
  local list="$1" token
  for token in $list; do
    [[ "$token" =~ ^[A-Za-z0-9._+:@-]+$ ]] || die "Unsafe DNF package token: $token"
    [[ "$token" != -* ]] || die "DNF package token must not start with '-': $token"
  done
}

validate_build_script_path() {
  local rel="$1"
  local IFS='/' part
  local -a parts
  [[ -z "$rel" ]] && return 0
  [[ "$rel" != /* ]] || die "BUILD_SCRIPT must be a relative path inside .codex-dev, not an absolute path."
  [[ "$rel" == .codex-dev/* ]] || die "BUILD_SCRIPT must point inside .codex-dev/, for example .codex-dev/build.sh"
  [[ "$rel" != *[[:space:]]* ]] || die "BUILD_SCRIPT path must not contain whitespace: $rel"
  [[ "$rel" != *":"* ]] || die "BUILD_SCRIPT path must not contain ':': $rel"
  read -r -a parts <<< "$rel"
  for part in "${parts[@]}"; do
    [[ -n "$part" && "$part" != "." && "$part" != ".." ]] || die "BUILD_SCRIPT contains an unsafe path component: $rel"
  done
}
load_project_config() {
  local name="$1" cfg line raw key val lineno
  project_path_real "$name" >/dev/null
  ensure_project_meta_safe "$name"
  cfg="$(project_config_path "$name")"
  [[ -f "$cfg" ]] || die "Project config missing: $cfg. Run: codex-dev init $name"
  [[ ! -L "$cfg" ]] || die "Project config must not be a symlink: $cfg"

  CFG_PROFILE="generic"
  CFG_FEDORA_IMAGE="$DEFAULT_FEDORA_IMAGE"
  CFG_DNF_PACKAGES=""
  CFG_READ_ONLY_ROOT="yes"
  CFG_BUILD_SCRIPT=""

  lineno=0
  while IFS= read -r raw || [[ -n "$raw" ]]; do
    lineno=$((lineno + 1))
    [[ "$raw" != *$'\r'* ]] || die "Invalid CR character in $cfg:$lineno. Use Unix line endings."
    line="$(strip_inline_comment "$raw")"
    line="$(trim "$line")"
    [[ -z "$line" ]] && continue
    [[ "$line" =~ ^([A-Z_][A-Z0-9_]*)=(.*)$ ]] || die "Invalid config line in $cfg:$lineno: $raw"
    key="${BASH_REMATCH[1]}"
    val="$(trim "${BASH_REMATCH[2]}")"
    val="$(strip_outer_quotes_or_die "$val" "$cfg" "$lineno")"
    case "$key" in
      PROFILE) CFG_PROFILE="$val" ;;
      FEDORA_IMAGE) CFG_FEDORA_IMAGE="$val" ;;
      DNF_PACKAGES) CFG_DNF_PACKAGES="$val" ;;
      READ_ONLY_ROOT) CFG_READ_ONLY_ROOT="$val" ;;
      BUILD_SCRIPT) CFG_BUILD_SCRIPT="$val" ;;
      *) die "Unsupported config key '$key' in $cfg:$lineno. This manager intentionally rejects arbitrary container args." ;;
    esac
  done < "$cfg"

  profile_exists "$CFG_PROFILE" || die "Unknown PROFILE '$CFG_PROFILE'. Run: codex-dev profiles"
  validate_fedora_image "$CFG_FEDORA_IMAGE"
  validate_package_tokens "$CFG_DNF_PACKAGES"
  case "$CFG_READ_ONLY_ROOT" in
    yes|no) ;;
    *) die "READ_ONLY_ROOT must be yes or no" ;;
  esac
  validate_build_script_path "$CFG_BUILD_SCRIPT"
}

resolve_build_script_or_empty() {
  local name="$1" rel="$2" project_real script_real meta_real script_path
  [[ -z "$rel" ]] && return 0
  project_real="$(project_path_real "$name")"
  script_path="$project_real/$rel"
  [[ -f "$script_path" ]] || die "BUILD_SCRIPT does not exist or is not a regular file: $script_path"
  [[ ! -L "$script_path" ]] || die "BUILD_SCRIPT must not be a symlink: $script_path"
  script_real="$(realpath -e "$script_path")"
  meta_real="$(realpath -e "$project_real/.codex-dev")"
  [[ "$script_real" == "$meta_real/"* ]] || die "BUILD_SCRIPT escaped .codex-dev: $script_real"
  printf '%s' "$script_real"
}

base_packages() {
  cat <<'PKGS'
ca-certificates curl git openssh-clients rsync bash bash-completion coreutils findutils diffutils grep sed gawk tar gzip xz unzip zip bzip2 patch procps-ng util-linux which hostname iproute iputils less nano vim-minimal jq file glibc-langpack-en make gcc gcc-c++ shadow-utils
PKGS
}

unique_words() {
  tr '[:space:]' '\n' | awk 'NF && !seen[$0]++ { print }' | tr '\n' ' '
}

image_name() {
  local name="$1"
  printf '%s/%s:latest' "$IMAGE_PREFIX" "$(resource_id "$name")"
}

container_name() {
  local name="$1"
  printf '%s-%s' "$CONTAINER_PREFIX" "$(resource_id "$name")"
}

volume_name() {
  local kind="$1" name="$2"
  printf '%s-%s-%s' "$CONTAINER_PREFIX" "$kind" "$(resource_id "$name")"
}

check_project_tree_safety() {
  local name="$1" real hit nested
  real="$(project_path_real "$name")"
  hit="$(find "$real" -xdev \( -type s -o -type p -o -type b -o -type c \) -print -quit 2>/dev/null || true)"
  [[ -z "$hit" ]] || die "Refusing project containing socket/FIFO/device file: $hit. Such files can expose host services into /workspace."
  if command -v findmnt >/dev/null 2>&1; then
    nested="$(findmnt -R -n -r -o TARGET 2>/dev/null | awk -v root="$real" '($0 != root) && index($0, root "/") == 1 { print; exit }')"
    [[ -z "$nested" ]] || die "Refusing project containing nested mount point: $nested. It can expose additional host paths."
  fi
  if [[ "${CODEX_DEV_ALLOW_HARDLINKS:-0}" != "1" ]]; then
    hit="$(find "$real" -xdev -type f -links +1 -print -quit 2>/dev/null || true)"
    [[ -z "$hit" ]] || die "Refusing project with hardlinked files: $hit. Hardlinks can share an inode with files outside /workspace. Replace hardlinks with copies, or set CODEX_DEV_ALLOW_HARDLINKS=1 only after auditing."
  fi
}

generate_containerfile() {
  local name="$1" dir pkgs profile_pkgs uid gid script_real hook_snippet
  load_project_config "$name"
  validate_image_prefix
  dir="$BUILD_ROOT/$(resource_id "$name")"
  mkdir -p "$dir" || die "Failed to create build directory: $dir"
  rm -f "$dir/Containerfile" "$dir/project-build.sh"
  uid="$(id -u)"
  gid="$(id -g)"
  profile_pkgs="$(profile_packages "$CFG_PROFILE")"
  pkgs="$(printf '%s %s %s\n' "$(base_packages)" "$profile_pkgs" "$CFG_DNF_PACKAGES" | unique_words)"

  hook_snippet=""
  script_real="$(resolve_build_script_or_empty "$name" "$CFG_BUILD_SCRIPT")"
  if [[ -n "$script_real" ]]; then
    cp "$script_real" "$dir/project-build.sh" || die "Failed to copy BUILD_SCRIPT into build context."
    chmod 0644 "$dir/project-build.sh" || die "Failed to set permissions on copied BUILD_SCRIPT."
    hook_snippet=$'COPY project-build.sh /tmp/codex-dev-project-build.sh\nRUN chmod 0755 /tmp/codex-dev-project-build.sh \\\n && /bin/bash /tmp/codex-dev-project-build.sh \\\n && rm -f /tmp/codex-dev-project-build.sh'
  fi

  cat > "$dir/Containerfile" <<EOF_CONTAINERFILE
# Generated by codex-dev. Do not edit this file directly.
# Edit $(project_config_path "$name") and run: codex-dev build $name
FROM $CFG_FEDORA_IMAGE

ARG USER_UID=$uid
ARG USER_GID=$gid

RUN dnf -y update \\
 && dnf -y install $pkgs \\
 && dnf clean all \\
 && rm -rf /var/cache/dnf

$hook_snippet

RUN mkdir -p /home/codex /home/codex/.codex /home/codex/.cache /home/codex/.npm /home/codex/.cargo /home/codex/.gradle /home/codex/go /home/codex/.local/bin /workspace $CODEX_INSTALL_CACHE $CODEX_INSTALL_DIR \\
 && if ! getent group "\${USER_GID}" >/dev/null; then groupadd -g "\${USER_GID}" codex; fi \\
 && if ! getent passwd "\${USER_UID}" >/dev/null; then useradd -m -u "\${USER_UID}" -g "\${USER_GID}" -s /bin/bash codex; fi \\
 && chown -R "\${USER_UID}:\${USER_GID}" /home/codex /workspace

RUN /bin/bash -o pipefail -c 'curl -fsSL https://chatgpt.com/codex/install.sh | CODEX_NON_INTERACTIVE=1 CODEX_INSTALL_DIR=$CODEX_INSTALL_DIR CODEX_HOME=$CODEX_INSTALL_CACHE sh' \\
 && chmod -R a+rX $CODEX_INSTALL_CACHE $CODEX_INSTALL_DIR \\
 && command -v codex \\
 && codex --version

ENV HOME=/home/codex
ENV USER=codex
ENV SHELL=/bin/bash
ENV CODEX_HOME=/home/codex/.codex
ENV PATH=/home/codex/.local/bin:$CODEX_INSTALL_DIR:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

WORKDIR /workspace
USER $uid:$gid
EOF_CONTAINERFILE

  printf '%s' "$dir/Containerfile"
}

podman_rootless_value() {
  podman info --format '{{.Host.Security.Rootless}}' 2>/dev/null || true
}

ensure_podman_rootless() {
  local rootless
  need_cmd podman
  rootless="$(podman_rootless_value)"
  [[ "$rootless" == "true" ]] || die "Could not confirm rootless Podman. podman info reported Rootless='${rootless:-unknown}'. Do not run this through sudo/rootful Podman."
}

setup_cmd() {
  ensure_setup_dirs
  ensure_podman_rootless
  need_cmd realpath
  need_cmd sha256sum
  need_cmd find
  ensure_projects_root_safe
  validate_image_prefix
  if [[ ":${PATH}:" != *":$HOME/.local/bin:"* ]]; then
    warn "Add ~/.local/bin to PATH if codex-dev is not found after install."
  fi
  log "Config dir: $CONFIG_DIR"
  log "Projects root: $PROJECTS_ROOT"
  log "OK"
}

init_cmd() {
  local name profile p cfg meta
  name="${1:-}"
  profile="${2:-generic}"
  [[ $# -le 2 ]] || die "Usage: codex-dev init <project> [profile]"
  require_project_name "$name"
  profile_exists "$profile" || die "Unknown profile '$profile'. Run: codex-dev profiles"
  ensure_setup_dirs
  need_cmd realpath
  need_cmd sha256sum
  ensure_projects_root_safe
  p="$(project_path_literal "$name")"
  meta="$p/.codex-dev"
  [[ "$p" != "$PROJECTS_ROOT" ]] || die "Refusing Projects root."
  [[ ! -L "$p" ]] || die "Project path must not be a symlink: $p"
  [[ ! -e "$p" || -d "$p" ]] || die "Project path exists but is not a directory: $p"
  if [[ -e "$meta" ]]; then
    [[ -d "$meta" && ! -L "$meta" ]] || die "Project metadata path exists but is unsafe: $meta"
  fi
  mkdir -p "$meta" || die "Failed to create project metadata directory: $meta"
  cfg="$(project_config_path "$name")"
  [[ ! -L "$cfg" ]] || die "Project config must not be a symlink: $cfg"
  if [[ ! -f "$cfg" ]]; then
    cat > "$cfg" <<EOF_CFG
# codex-dev project environment
# This file is declarative. It cannot add mounts, host namespaces, privileged mode, sockets, or devices.
# Syntax: KEY=VALUE, one assignment per line. This is not a shell script.

PROFILE=$profile
FEDORA_IMAGE=$DEFAULT_FEDORA_IMAGE
READ_ONLY_ROOT=yes

# Add Fedora packages here. Package names only; shell syntax is intentionally rejected.
# Examples:
# DNF_PACKAGES="python3-pip nodejs npm cmake ninja-build openssl-devel"
DNF_PACKAGES=""

# Optional build hook. To run build-time commands, create .codex-dev/build.sh and set:
# BUILD_SCRIPT=".codex-dev/build.sh"
BUILD_SCRIPT=""
EOF_CFG
  fi
  if command -v git >/dev/null 2>&1 && [[ ! -d "$p/.git" ]]; then
    (cd "$p" && git init -q) || warn "Git init skipped or failed."
  fi
  log "Project created: $p"
  log "Config: $cfg"
  log "Next: codex-dev build $name"
}

list_cmd() {
  local show_all="no"
  case "$#" in
    0) ;;
    1)
      [[ "${1:-}" == "-a" ]] || die "Usage: codex-dev list [-a]"
      show_all="yes"
      ;;
    *) die "Usage: codex-dev list [-a]" ;;
  esac

  validate_host_path_string "Build root" "$BUILD_ROOT"
  validate_image_prefix
  need_cmd sha256sum

  if [[ "$show_all" == "yes" ]]; then
    list_all_projects
  else
    list_built_projects
  fi
}

image_name_from_resource_id() {
  local rid="$1"
  printf '%s/%s:latest' "$IMAGE_PREFIX" "$rid"
}

container_name_from_resource_id() {
  local rid="$1"
  printf '%s-%s' "$CONTAINER_PREFIX" "$rid"
}

volume_name_from_resource_id() {
  local kind="$1" rid="$2"
  printf '%s-%s-%s' "$CONTAINER_PREFIX" "$kind" "$rid"
}

volume_names_from_resource_id() {
  local rid="$1" kind first=1
  for kind in home cache npm cargo gradle go; do
    if [[ "$first" -eq 1 ]]; then
      first=0
    else
      printf ','
    fi
    volume_name_from_resource_id "$kind" "$rid"
  done
}

container_status_by_resource_id() {
  local rid="$1" cname status
  cname="$(container_name_from_resource_id "$rid")"
  if ! command -v podman >/dev/null 2>&1; then
    printf 'unknown'
    return 0
  fi
  if podman container exists "$cname" >/dev/null 2>&1; then
    status="$(podman inspect -f '{{.State.Status}}' "$cname" 2>/dev/null || printf 'unknown')"
    printf '%s' "${status:-unknown}"
  else
    printf 'not-present'
  fi
}

build_record_name_from_containerfile() {
  local rid="$1" cf line
  cf="$BUILD_ROOT/$rid/Containerfile"
  [[ -f "$cf" && ! -L "$cf" ]] || return 1
  line="$(grep -E '^# Edit .+ and run: codex-dev build [A-Za-z0-9._-]+$' "$cf" 2>/dev/null | head -n 1 || true)"
  [[ -n "$line" ]] || return 1
  line="${line##* and run: codex-dev build }"
  valid_project_name "$line" || return 1
  printf '%s' "$line"
}

build_record_project_path_from_containerfile() {
  local rid="$1" cf line cfg project
  cf="$BUILD_ROOT/$rid/Containerfile"
  [[ -f "$cf" && ! -L "$cf" ]] || return 1
  line="$(grep -E '^# Edit .+ and run: codex-dev build [A-Za-z0-9._-]+$' "$cf" 2>/dev/null | head -n 1 || true)"
  [[ -n "$line" ]] || return 1
  cfg="${line#"# Edit "}"
  cfg="${cfg% and run: codex-dev build *}"
  [[ "$cfg" == */.codex-dev/project.env ]] || return 1
  project="${cfg%/.codex-dev/project.env}"
  [[ -n "$project" ]] || return 1
  printf '%s' "$project"
}

build_record_resource_ids() {
  local d rid nullglob_was_set=0
  [[ -d "$BUILD_ROOT" && ! -L "$BUILD_ROOT" ]] || return 0
  shopt -q nullglob && nullglob_was_set=1
  shopt -s nullglob
  for d in "$BUILD_ROOT"/*; do
    [[ -d "$d" && ! -L "$d" ]] || continue
    rid="$(basename "$d")"
    [[ "$rid" =~ ^[A-Za-z0-9_.-]+-[0-9a-f]{10}$ ]] || continue
    printf '%s\n' "$rid"
  done
  if [[ "$nullglob_was_set" -eq 1 ]]; then
    shopt -s nullglob
  else
    shopt -u nullglob
  fi
}

list_built_projects() {
  local found=0 rid name path status img
  while IFS= read -r rid; do
    [[ -n "$rid" ]] || continue
    name="$(build_record_name_from_containerfile "$rid" 2>/dev/null || printf '%s' "$rid")"
    path="$(build_record_project_path_from_containerfile "$rid" 2>/dev/null || printf '%s' "$BUILD_ROOT/$rid")"
    status="$(container_status_by_resource_id "$rid")"
    img="$(image_name_from_resource_id "$rid")"
    printf '%-28s  %-12s  %s  %s\n' "$name" "$status" "$img" "$path"
    found=1
  done < <(build_record_resource_ids)
  [[ "$found" -eq 1 ]] || log "No built projects under $BUILD_ROOT"
}

list_all_projects() {
  local rid name path status img cname vols project_name project_rid
  declare -A row_name=() row_path=() row_state=()

  while IFS= read -r rid; do
    [[ -n "$rid" ]] || continue
    name="$(build_record_name_from_containerfile "$rid" 2>/dev/null || printf '%s' "$rid")"
    path="$(build_record_project_path_from_containerfile "$rid" 2>/dev/null || printf '%s' "$BUILD_ROOT/$rid")"
    row_name["$rid"]="$name"
    row_path["$rid"]="$path"
    row_state["$rid"]="已build"
  done < <(build_record_resource_ids)

  while IFS= read -r project_name; do
    [[ -n "$project_name" ]] || continue
    project_rid="$(resource_id "$project_name")"
    if [[ -n "${row_state[$project_rid]:-}" ]]; then
      [[ "${row_name[$project_rid]}" == "$project_rid" ]] && row_name["$project_rid"]="$project_name"
      row_path["$project_rid"]="$(project_path_literal "$project_name")"
      row_state["$project_rid"]="已build"
    else
      row_name["$project_rid"]="$project_name"
      row_path["$project_rid"]="$(project_path_literal "$project_name")"
      row_state["$project_rid"]="已init"
    fi
  done < <(managed_project_names)

  if [[ "${#row_name[@]}" -eq 0 ]]; then
    log "No initialized or built projects found."
    return 0
  fi

  for rid in "${!row_name[@]}"; do
    if [[ "${row_state[$rid]}" == "已build" ]]; then
      status="$(container_status_by_resource_id "$rid")"
      cname="$(container_name_from_resource_id "$rid")"
      img="$(image_name_from_resource_id "$rid")"
      vols="$(volume_names_from_resource_id "$rid")"
    else
      status="-"
      cname="-"
      img="-"
      vols="-"
    fi
    printf '%-28s  %-40s  %-8s  status=%s  container=%s  image=%s  volumes=%s\n' \
      "${row_name[$rid]}" "${row_path[$rid]}" "${row_state[$rid]}" "$status" "$cname" "$img" "$vols"
  done | sort
}

candidate_matches_prefix() {
  local candidate="$1" prefix="$2"
  [[ -z "$prefix" || "$candidate" == "$prefix"* ]]
}

emit_matching_candidates() {
  local prefix="$1" candidate
  shift
  for candidate in "$@"; do
    candidate_matches_prefix "$candidate" "$prefix" && printf '%s\n' "$candidate"
  done
  return 0
}

emit_matching_lines() {
  local prefix="$1" line
  while IFS= read -r line; do
    [[ -n "$line" ]] || continue
    candidate_matches_prefix "$line" "$prefix" && printf '%s\n' "$line"
  done
  return 0
}

word_present_after_project() {
  local needle="$1" start="$2"
  local i
  shift 2
  local words=("$@")
  for ((i = start; i < ${#words[@]}; i++)); do
    [[ "${words[i]}" == "$needle" ]] && return 0
  done
  return 1
}

complete_cmd_internal() {
  local current=""
  local -a candidates
  if [[ "${1:-}" != "--current" || $# -lt 3 ]]; then
    die "Usage: codex-dev __complete --current <1-based-index> -- <words...>"
  fi
  shift
  current="$1"
  shift
  [[ "$current" =~ ^[0-9]+$ && "$current" -ge 1 ]] || die "__complete --current must be a 1-based integer"
  [[ "${1:-}" == "--" ]] || die "Usage: codex-dev __complete --current <1-based-index> -- <words...>"
  shift

  local words=("$@")
  local idx=$((current - 1))
  local cur="${words[idx]:-}"
  local cmd="${words[1]:-}"

  if [[ "$current" -le 2 ]]; then
    mapfile -t candidates < <(public_commands)
    emit_matching_candidates "$cur" "${candidates[@]}"
    return 0
  fi

  case "$cmd" in
    init)
      if [[ "$current" -eq 4 ]]; then
        mapfile -t candidates < <(profile_names)
        emit_matching_candidates "$cur" "${candidates[@]}"
      fi
      ;;
    config|edit|edit-build-script|build|shell|omx|codex|exec|doctor|volumes|reset-cache|reset-home|nuke-env)
      if [[ "$current" -eq 3 ]]; then
        managed_project_names | emit_matching_lines "$cur"
      elif [[ "$cmd" == "shell" || "$cmd" == "omx" ]] && [[ "$current" -ge 4 ]]; then
        if ! word_present_after_project "--rw-root" 3 "${words[@]}"; then
          emit_matching_candidates "$cur" "--rw-root"
        fi
      elif [[ "$cmd" == "codex" || "$cmd" == "exec" ]]; then
        if word_present_after_project "--" 3 "${words[@]}"; then
          return 0
        fi
        candidates=()
        word_present_after_project "--rw-root" 3 "${words[@]}" || candidates+=("--rw-root")
        candidates+=("--")
        emit_matching_candidates "$cur" "${candidates[@]}"
      fi
      ;;
    attach)
      local attach_sub="${words[2]:-}"
      if [[ "$current" -eq 3 ]]; then
        emit_matching_candidates "$cur" shell omx codex exec
      elif [[ "$current" -eq 4 ]]; then
        managed_project_names | emit_matching_lines "$cur"
      elif [[ "$current" -ge 5 ]]; then
        case "$attach_sub" in
          shell|omx)
            if ! word_present_after_project "--rw-root" 4 "${words[@]}"; then
              emit_matching_candidates "$cur" "--rw-root"
            fi
            ;;
          codex|exec)
            if word_present_after_project "--" 4 "${words[@]}"; then
              return 0
            fi
            candidates=()
            word_present_after_project "--rw-root" 4 "${words[@]}" || candidates+=("--rw-root")
            candidates+=("--")
            emit_matching_candidates "$cur" "${candidates[@]}"
            ;;
        esac
      fi
      ;;
    completion)
      if [[ "$current" -eq 3 ]]; then
        emit_matching_candidates "$cur" zsh
      elif [[ "$current" -eq 4 && "${words[2]:-}" == "zsh" ]]; then
        emit_matching_candidates "$cur" --command
      fi
      ;;
  esac
}

single_quote_for_zsh() {
  local s="$1"
  printf "'%s'" "${s//\'/\'\\\'\'}"
}

completion_zsh() {
  local cmd_path="$1" quoted
  quoted="$(single_quote_for_zsh "$cmd_path")"
  cat <<EOF_ZSH
#compdef codex-dev

_codex-dev() {
  local _codex_dev_cmd=$quoted
  local -a _codex_dev_candidates
  _codex_dev_candidates=(\${(@f)\$("\$_codex_dev_cmd" __complete --current "\$CURRENT" -- "\${words[@]}" 2>/dev/null)})
  (( \${#_codex_dev_candidates[@]} )) || return 1
  compadd -- "\${_codex_dev_candidates[@]}"
}

_codex-dev "\$@"
EOF_ZSH
}

completion_cmd() {
  local shell="${1:-}" cmd_path
  [[ -n "$shell" ]] || die "Usage: codex-dev completion zsh [--command <absolute-path>]"
  shift || true
  case "$shell" in
    zsh)
      if [[ "${1:-}" == "--command" ]]; then
        [[ $# -eq 2 ]] || die "Usage: codex-dev completion zsh [--command <absolute-path>]"
        cmd_path="$2"
        [[ "$cmd_path" == /* ]] || die "--command must be an absolute path"
      else
        [[ $# -eq 0 ]] || die "Usage: codex-dev completion zsh [--command <absolute-path>]"
        cmd_path="$(command -v codex-dev 2>/dev/null || true)"
        [[ -n "$cmd_path" ]] || cmd_path="codex-dev"
      fi
      completion_zsh "$cmd_path"
      ;;
    bash|fish)
      die "$shell completion is not supported yet. Zsh is the only supported completion shell in this release."
      ;;
    *)
      die "Unsupported completion shell '$shell'. Usage: codex-dev completion zsh [--command <absolute-path>]"
      ;;
  esac
}

config_cmd() {
  local name="$1"
  require_project_name "$name"
  project_path_real "$name" >/dev/null
  ensure_project_meta_safe "$name"
  local cfg
  cfg="$(project_config_path "$name")"
  [[ -f "$cfg" ]] || die "Project config missing: $cfg"
  [[ ! -L "$cfg" ]] || die "Project config must not be a symlink: $cfg"
  printf '%s\n' "$cfg"
}

edit_cmd() {
  local name="$1" editor cfg
  require_project_name "$name"
  project_path_real "$name" >/dev/null
  ensure_project_meta_safe "$name"
  cfg="$(project_config_path "$name")"
  [[ -f "$cfg" ]] || die "Project config missing: $cfg"
  [[ ! -L "$cfg" ]] || die "Project config must not be a symlink: $cfg"
  editor="${EDITOR:-nano}"
  command -v "$editor" >/dev/null 2>&1 || die "Editor not found: $editor. Set EDITOR or install nano/vim."
  "$editor" "$cfg"
}

edit_build_script_cmd() {
  local name="$1" editor script
  require_project_name "$name"
  project_path_real "$name" >/dev/null
  ensure_project_meta_safe "$name"
  script="$(project_path_literal "$name")/.codex-dev/build.sh"
  [[ ! -L "$script" ]] || die "Build script must not be a symlink: $script"
  if [[ ! -f "$script" ]]; then
    cat > "$script" <<'EOF_SCRIPT'
#!/usr/bin/env bash
set -Eeuo pipefail

# Build-time commands run inside the image build container as root.
# They do not get host mounts, Podman/Docker sockets, or your host HOME.
# Example:
# dnf -y install ffmpeg portaudio-devel && dnf clean all
EOF_SCRIPT
    chmod 0755 "$script" || die "Failed to chmod build script: $script"
    log "Created: $script"
    log "Enable it in project.env with: BUILD_SCRIPT=\".codex-dev/build.sh\""
  fi
  editor="${EDITOR:-nano}"
  command -v "$editor" >/dev/null 2>&1 || die "Editor not found: $editor. Set EDITOR or install nano/vim."
  "$editor" "$script"
}

build_cmd() {
  local name="$1" cf img
  require_project_name "$name"
  ensure_setup_dirs
  ensure_podman_rootless
  need_cmd realpath
  need_cmd sha256sum
  need_cmd find
  ensure_projects_root_safe
  check_project_tree_safety "$name"
  cf="$(generate_containerfile "$name")"
  img="$(image_name "$name")"
  log "Building image: $img"
  log "Containerfile: $cf"
  podman build --pull=newer -t "$img" -f "$cf" "$(dirname "$cf")" || die "podman build failed for project '$name'. Check project.env, DNF_PACKAGES, BUILD_SCRIPT, and network access."
}

declare -a CONTAINER_ARGS=()

container_base_args() {
  local name="$1" rw_root="$2" project_real home_vol cache_vol npm_vol cargo_vol gradle_vol go_vol
  project_real="$(project_path_real "$name")"
  home_vol="$(volume_name home "$name")"
  cache_vol="$(volume_name cache "$name")"
  npm_vol="$(volume_name npm "$name")"
  cargo_vol="$(volume_name cargo "$name")"
  gradle_vol="$(volume_name gradle "$name")"
  go_vol="$(volume_name go "$name")"

  CONTAINER_ARGS=(
    --rm
    --interactive
    --tty
    --name "$(container_name "$name")"
    --hostname "$(container_name "$name")"
    --userns=keep-id
    --user "$(id -u):$(id -g)"
    --workdir /workspace
    --env HOME=/home/codex
    --env USER=codex
    --env SHELL=/bin/bash
    --env CODEX_HOME=/home/codex/.codex
    --security-opt no-new-privileges
    --cap-drop ALL
    --pids-limit 4096
    --tmpfs /tmp:rw,nosuid,nodev,exec,size=2g
    --tmpfs /run:rw,nosuid,nodev,noexec,size=128m
    --tmpfs /var/tmp:rw,nosuid,nodev,exec,size=2g
    --volume "$project_real:/workspace:Z,rw"
    --volume "$home_vol:/home/codex:Z,U"
    --volume "$cache_vol:/home/codex/.cache:Z,U"
    --volume "$npm_vol:/home/codex/.npm:Z,U"
    --volume "$cargo_vol:/home/codex/.cargo:Z,U"
    --volume "$gradle_vol:/home/codex/.gradle:Z,U"
    --volume "$go_vol:/home/codex/go:Z,U"
  )

  if [[ "$rw_root" != "yes" ]]; then
    CONTAINER_ARGS+=(--read-only)
  fi
}

ensure_container_slot() {
  local name="$1" cname state
  cname="$(container_name "$name")"
  if podman container exists "$cname"; then
    state="$(podman inspect -f '{{.State.Status}}' "$cname" 2>/dev/null || printf 'unknown')"
    case "$state" in
      running|paused)
        die "Container '$cname' is already $state. Exit it first, or remove it with: podman rm -f $cname"
        ;;
      *)
        warn "Removing stale container '$cname' with state '$state'."
        podman rm -f "$cname" >/dev/null || die "Failed to remove stale container: $cname"
        ;;
    esac
  fi
}

run_container() {
  local name="$1" rw_root_requested="$2" img effective_rw_root
  shift 2
  require_project_name "$name"
  ensure_setup_dirs
  ensure_podman_rootless
  need_cmd realpath
  need_cmd sha256sum
  need_cmd find
  ensure_projects_root_safe
  load_project_config "$name"
  check_project_tree_safety "$name"
  validate_image_prefix
  img="$(image_name "$name")"
  if ! podman image exists "$img"; then
    log "Image missing. Building first: $img"
    build_cmd "$name"
  fi
  case "$rw_root_requested" in
    auto)
      if [[ "$CFG_READ_ONLY_ROOT" == "yes" ]]; then effective_rw_root="no"; else effective_rw_root="yes"; fi
      ;;
    yes|no)
      effective_rw_root="$rw_root_requested"
      ;;
    *) die "Internal error: invalid rw_root value: $rw_root_requested" ;;
  esac
  ensure_container_slot "$name"
  container_base_args "$name" "$effective_rw_root"
  log "Project mount: $(project_path_real "$name") -> /workspace"
  log "Root filesystem writable: $effective_rw_root"
  log "Host home, ~/Projects parent, SSH keys, config dirs, Podman socket, host namespaces, and devices are not mounted."
  local rc
  set +e
  podman run "${CONTAINER_ARGS[@]}" "$img" /bin/bash -lc '
    set -Eeuo pipefail
    umask 077
    mkdir -p "$HOME" "$CODEX_HOME" "$HOME/.cache" "$HOME/.npm" "$HOME/.cargo" "$HOME/.gradle" "$HOME/go" "$HOME/.local/bin"
    chmod 700 "$HOME" "$CODEX_HOME" 2>/dev/null || true
    exec "$@"
  ' codex-dev-runtime-init "$@"
  rc=$?
  set -e
  if [[ "$rc" -ne 0 ]]; then
    warn "podman run exited with status $rc."
  fi
  return "$rc"
}

parse_rw_flag() {
  RW_ROOT="auto"
  if [[ "${1:-}" == "--rw-root" ]]; then
    RW_ROOT="yes"
    shift
  fi
  REMAINING_ARGS=("$@")
}

shell_cmd() {
  local name="$1"; shift || true
  parse_rw_flag "$@"
  [[ "${#REMAINING_ARGS[@]}" -eq 0 ]] || die "codex-dev shell only accepts --rw-root after the project name."
  run_container "$name" "$RW_ROOT" /bin/bash -l
}

omx_cmd() {
  local name="$1"; shift || true
  parse_rw_flag "$@"
  [[ "${#REMAINING_ARGS[@]}" -eq 0 ]] || die "codex-dev omx only accepts --rw-root after the project name."
  run_container "$name" "$RW_ROOT" omx --madmax --high
}

codex_cmd() {
  local name="$1"; shift || true
  parse_rw_flag "$@"
  local extra=("${REMAINING_ARGS[@]}")
  if [[ "${extra[0]:-}" == "--" ]]; then
    extra=("${extra[@]:1}")
  fi
  run_container "$name" "$RW_ROOT" codex --cd /workspace --sandbox danger-full-access --ask-for-approval never "${extra[@]}"
}

exec_cmd() {
  local name="$1"; shift || true
  parse_rw_flag "$@"
  local prompt_args=("${REMAINING_ARGS[@]}")
  if [[ "${prompt_args[0]:-}" == "--" ]]; then
    prompt_args=("${prompt_args[@]:1}")
  fi
  [[ "${#prompt_args[@]}" -gt 0 ]] || die "Provide a prompt after --"
  run_container "$name" "$RW_ROOT" codex exec --cd /workspace --sandbox danger-full-access --ask-for-approval never "${prompt_args[*]}"
}

attach_or_run() {
  local name="$1" rw_root="$2" cname state
  shift 2
  ensure_podman_rootless
  need_cmd sha256sum
  cname="$(container_name "$name")"
  if podman container exists "$cname"; then
    state="$(podman inspect -f '{{.State.Status}}' "$cname" 2>/dev/null || printf 'unknown')"
    case "$state" in
      running)
        log "Attaching current terminal to running container: $cname"
        podman exec -it "$cname" "$@"
        ;;
      paused)
        die "Container '$cname' is paused. Unpause or stop it before using codex-dev attach."
        ;;
      *)
        log "Container '$cname' is not running (state: ${state:-unknown}); starting normal '$1' command flow."
        run_container "$name" "$rw_root" "$@"
        ;;
    esac
  else
    run_container "$name" "$rw_root" "$@"
  fi
}

attach_cmd() {
  local sub="${1:-}" name
  [[ -n "$sub" ]] || die "Usage: codex-dev attach <shell|omx|codex|exec> <project> [...]"
  shift || true
  case "$sub" in
    shell)
      [[ $# -ge 1 ]] || die "Usage: codex-dev attach shell <project> [--rw-root]"
      name="$1"; shift
      require_project_name "$name"
      parse_rw_flag "$@"
      [[ "${#REMAINING_ARGS[@]}" -eq 0 ]] || die "codex-dev attach shell only accepts --rw-root after the project name."
      attach_or_run "$name" "$RW_ROOT" /bin/bash -l
      ;;
    omx)
      [[ $# -ge 1 ]] || die "Usage: codex-dev attach omx <project> [--rw-root]"
      name="$1"; shift
      require_project_name "$name"
      parse_rw_flag "$@"
      [[ "${#REMAINING_ARGS[@]}" -eq 0 ]] || die "codex-dev attach omx only accepts --rw-root after the project name."
      attach_or_run "$name" "$RW_ROOT" omx --madmax --high
      ;;
    codex)
      [[ $# -ge 1 ]] || die "Usage: codex-dev attach codex <project> [--rw-root] [-- <extra codex args...>]"
      name="$1"; shift
      require_project_name "$name"
      parse_rw_flag "$@"
      local extra=("${REMAINING_ARGS[@]}")
      if [[ "${extra[0]:-}" == "--" ]]; then
        extra=("${extra[@]:1}")
      fi
      attach_or_run "$name" "$RW_ROOT" codex --cd /workspace --sandbox danger-full-access --ask-for-approval never "${extra[@]}"
      ;;
    exec)
      [[ $# -ge 1 ]] || die "Usage: codex-dev attach exec <project> [--rw-root] -- <prompt>"
      name="$1"; shift
      require_project_name "$name"
      parse_rw_flag "$@"
      local prompt_args=("${REMAINING_ARGS[@]}")
      if [[ "${prompt_args[0]:-}" == "--" ]]; then
        prompt_args=("${prompt_args[@]:1}")
      fi
      [[ "${#prompt_args[@]}" -gt 0 ]] || die "Provide a prompt after --"
      attach_or_run "$name" "$RW_ROOT" codex exec --cd /workspace --sandbox danger-full-access --ask-for-approval never "${prompt_args[*]}"
      ;;
    *)
      die "Usage: codex-dev attach <shell|omx|codex|exec> <project> [...]"
      ;;
  esac
}

volumes_cmd() {
  local name="$1" kind
  require_project_name "$name"
  need_cmd sha256sum
  for kind in home cache npm cargo gradle go; do
    printf '%-8s %s\n' "$kind" "$(volume_name "$kind" "$name")"
  done
}

remove_volume_if_exists() {
  local vol="$1"
  if podman volume exists "$vol"; then
    podman volume rm "$vol" >/dev/null || die "Failed to remove volume '$vol'. A container may still be using it."
    log "Removed volume: $vol"
  else
    log "Volume not present: $vol"
  fi
}

reset_cache_cmd() {
  local name="$1" kind vol
  require_project_name "$name"
  ensure_podman_rootless
  need_cmd sha256sum
  for kind in cache npm cargo gradle go; do
    vol="$(volume_name "$kind" "$name")"
    remove_volume_if_exists "$vol"
  done
}

reset_home_cmd() {
  local name="$1" vol
  require_project_name "$name"
  ensure_podman_rootless
  need_cmd sha256sum
  vol="$(volume_name home "$name")"
  remove_volume_if_exists "$vol"
  log "Codex login/config for this project was removed if that volume existed. Project files were not touched."
}

nuke_env_cmd() {
  local name="$1" img kind vol cname build_dir
  require_project_name "$name"
  ensure_podman_rootless
  need_cmd sha256sum
  validate_host_path_string "Build root" "$BUILD_ROOT"
  validate_image_prefix
  img="$(image_name "$name")"
  cname="$(container_name "$name")"
  if podman container exists "$cname"; then
    podman rm -f "$cname" >/dev/null || die "Failed to remove container: $cname"
    log "Removed container: $cname"
  else
    log "Container not present: $cname"
  fi
  if podman image exists "$img"; then
    podman image rm -f "$img" >/dev/null || die "Failed to remove image: $img"
    log "Removed image: $img"
  else
    log "Image not present: $img"
  fi
  for kind in home cache npm cargo gradle go; do
    vol="$(volume_name "$kind" "$name")"
    remove_volume_if_exists "$vol"
  done
  build_dir="$BUILD_ROOT/$(resource_id "$name")"
  if [[ -e "$build_dir" || -L "$build_dir" ]] && path_has_symlink_parent "$build_dir"; then
    die "Refusing to remove build directory through symlinked parent; inspect manually: $build_dir"
  elif [[ -L "$build_dir" ]]; then
    die "Refusing to remove symlinked build directory: $build_dir"
  elif [[ -d "$build_dir" ]]; then
    rm -rf -- "$build_dir" || die "Failed to remove build directory: $build_dir"
    log "Removed build directory: $build_dir"
  else
    log "Build directory not present: $build_dir"
  fi
  log "Project directory was not touched: $(project_path_literal "$name")"
}

MARKER_BEGIN="# BEGIN codex-dev zsh completion"
MARKER_END="# END codex-dev zsh completion"

prompt_yes_no() {
  local prompt="$1" default="${2:-no}" answer suffix
  case "$default" in
    yes) suffix="[Y/n]" ;;
    no) suffix="[y/N]" ;;
    *) die "Internal error: invalid prompt default: $default" ;;
  esac
  while true; do
    printf '%s %s ' "$prompt" "$suffix" >&2
    if ! IFS= read -r answer; then
      answer=""
    fi
    answer="$(trim "$answer")"
    if [[ -z "$answer" ]]; then
      [[ "$default" == "yes" ]] && return 0 || return 1
    fi
    case "$answer" in
      y|Y|yes|YES|Yes) return 0 ;;
      n|N|no|NO|No) return 1 ;;
      *) warn "Please answer yes or no." ;;
    esac
  done
}

zshrc_path() {
  local zdot
  zdot="$(expand_leading_tilde "${ZDOTDIR:-$HOME}")"
  printf '%s/.zshrc' "$zdot"
}

zshrc_has_codex_dev_marker() {
  local rc="$1"
  [[ -f "$rc" && ! -L "$rc" ]] || return 1
  local line in_marker=0 begin_count=0 end_count=0 malformed=0
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$MARKER_BEGIN" ]]; then
      if [[ "$in_marker" -eq 1 ]]; then
        malformed=1
      fi
      in_marker=1
      begin_count=$((begin_count + 1))
      continue
    fi
    if [[ "$line" == "$MARKER_END" ]]; then
      if [[ "$in_marker" -ne 1 ]]; then
        malformed=1
      fi
      in_marker=0
      end_count=$((end_count + 1))
      continue
    fi
  done < "$rc"
  [[ "$in_marker" -eq 0 && "$malformed" -eq 0 && "$begin_count" -eq 1 && "$end_count" -eq 1 ]]
}

zshrc_has_any_codex_dev_marker() {
  local rc="$1"
  [[ -f "$rc" && ! -L "$rc" ]] || return 1
  grep -Fxq "$MARKER_BEGIN" "$rc" || grep -Fxq "$MARKER_END" "$rc"
}

remove_codex_dev_zsh_marker() {
  local rc="$1" tmp line in_marker=0 removed=0
  if [[ -L "$rc" ]]; then
    warn "Not modifying symlinked zsh rc: $rc"
    return 0
  fi
  if path_has_symlink_parent "$rc"; then
    warn "Not modifying zsh rc through symlinked parent; inspect manually: $rc"
    return 0
  fi
  [[ -f "$rc" ]] || return 0
  if ! zshrc_has_codex_dev_marker "$rc"; then
    if zshrc_has_any_codex_dev_marker "$rc"; then
      warn "Not modifying malformed zsh rc marker block; inspect manually: $rc"
    fi
    return 0
  fi
  tmp="$(mktemp "$(dirname "$rc")/.$(basename "$rc").codex-dev-uninstall.XXXXXX")" || die "Failed to create temporary rc file next to $rc"
  cp -p -- "$rc" "$tmp" 2>/dev/null || true
  : > "$tmp"
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" == "$MARKER_BEGIN" ]]; then
      in_marker=1
      removed=1
      continue
    fi
    if [[ "$line" == "$MARKER_END" && "$in_marker" -eq 1 ]]; then
      in_marker=0
      continue
    fi
    [[ "$in_marker" -eq 1 ]] && continue
    printf '%s\n' "$line" >> "$tmp"
  done < "$rc"
  if [[ "$removed" -eq 1 ]]; then
    chmod --reference="$rc" "$tmp" 2>/dev/null || true
    mv "$tmp" "$rc"
    log "Removed zsh rc marker: $rc"
  else
    rm -f "$tmp"
  fi
}

podman_exists_quietly() {
  local kind="$1" name="$2"
  command -v podman >/dev/null 2>&1 || return 1
  case "$kind" in
    container) podman container exists "$name" >/dev/null 2>&1 ;;
    image) podman image exists "$name" >/dev/null 2>&1 ;;
    volume) podman volume exists "$name" >/dev/null 2>&1 ;;
    *) return 1 ;;
  esac
}

print_plan_section() {
  local title="$1"
  shift
  printf '%s\n' "$title"
  if [[ "$#" -eq 0 ]]; then
    printf '  (none)\n'
    return 0
  fi
  local item
  for item in "$@"; do
    printf '  - %s\n' "$item"
  done
}

strip_trailing_slashes() {
  local path="$1"
  while [[ "$path" != "/" && "$path" == */ ]]; do
    path="${path%/}"
  done
  printf '%s' "$path"
}

path_has_symlink_parent() {
  local path="$1" dir parent root_seen=0
  dir="$(dirname "$path")"
  [[ "$dir" == "." ]] && return 1
  while [[ "$dir" != "/" && "$dir" != "." ]]; do
    if [[ -L "$dir" ]]; then
      return 0
    fi
    parent="$(dirname "$dir")"
    [[ "$parent" != "$dir" ]] || break
    dir="$parent"
    root_seen=1
  done
  [[ "$root_seen" -eq 1 ]] || return 1
  return 1
}

add_uninstall_file_target_or_note() {
  local path="$1" label="$2"
  path="$(strip_trailing_slashes "$path")"
  [[ -e "$path" && ! -d "$path" ]] || return 0
  if path_has_symlink_parent "$path"; then
    notes+=("Not automatically removing $label through symlinked parent; inspect manually: $path")
    return 0
  fi
  file_targets+=("$path")
}

add_empty_parent_target_or_note() {
  local path="$1" label="$2"
  local base parent
  path="$(strip_trailing_slashes "$path")"
  [[ -d "$path" && ! -L "$path" ]] || return 0
  if path_has_symlink_parent "$path"; then
    notes+=("Not automatically pruning $label directory through symlinked parent; inspect manually: $path")
    return 0
  fi
  base="$(basename "$path")"
  parent="$(dirname "$path")"
  if [[ "$base" == "codex-dev" && "$path" != "/" && "$path" != "$HOME" && "$path" != "$parent" ]]; then
    empty_dir_targets+=("$path")
  else
    notes+=("Not automatically pruning broad $label directory; inspect manually: $path")
  fi
}

add_generated_dir_target() {
  local path="$1" label="$2"
  path="$(strip_trailing_slashes "$path")"
  if [[ -d "$path" && ! -L "$path" ]]; then
    if path_has_symlink_parent "$path"; then
      notes+=("Not automatically removing $label directory through symlinked parent; inspect manually: $path")
      return 0
    fi
    generated_dir_targets+=("$path")
  elif [[ -L "$path" ]]; then
    notes+=("Not automatically removing symlinked $label directory; inspect manually: $path")
  fi
}

uninstall_cmd() {
  [[ $# -eq 0 ]] || die "Usage: codex-dev uninstall"
  local remove_images="no" remove_volumes="no" data_home zsh_completion data_dir zsh_snippet rc installed_bin
  local name kind cname img vol config_dir_norm build_root_norm
  local -a file_targets=() generated_dir_targets=() empty_dir_targets=() rc_targets=() rc_plan_targets=() containers=() images=() volumes=() notes=()

  if prompt_yes_no "Remove codex-dev Podman images?" no; then
    remove_images="yes"
  fi
  if prompt_yes_no "Remove codex-dev Podman volumes, including per-project Codex login/cache state?" no; then
    remove_volumes="yes"
  fi

  data_home="$(expand_leading_tilde "${XDG_DATA_HOME:-$HOME/.local/share}")"
  installed_bin="$HOME/.local/bin/codex-dev"
  zsh_completion="$data_home/zsh/site-functions/_codex-dev"
  data_dir="$data_home/codex-dev"
  zsh_snippet="$data_dir/zsh-completion.zsh"
  rc="$(zshrc_path)"

  add_uninstall_file_target_or_note "$installed_bin" "installed binary"
  add_uninstall_file_target_or_note "$zsh_completion" "zsh completion"
  add_uninstall_file_target_or_note "$zsh_snippet" "zsh snippet"
  config_dir_norm="$(strip_trailing_slashes "$CONFIG_DIR")"
  build_root_norm="$config_dir_norm/build"
  if [[ -d "$config_dir_norm" && ! -L "$config_dir_norm" && "$(basename "$config_dir_norm")" == "codex-dev" ]]; then
    add_generated_dir_target "$build_root_norm" "config build"
  elif [[ -d "$build_root_norm" ]]; then
    notes+=("Not automatically removing build directory under broad config path; inspect manually: $build_root_norm")
  elif [[ -L "$config_dir_norm" ]]; then
    notes+=("Not automatically removing symlinked config directory; inspect manually: $config_dir_norm")
  fi
  add_empty_parent_target_or_note "$config_dir_norm" "config"
  add_empty_parent_target_or_note "$data_dir" "data"
  if zshrc_has_codex_dev_marker "$rc"; then
    if path_has_symlink_parent "$rc"; then
      notes+=("Not automatically editing zsh rc through symlinked parent; inspect manually: $rc")
    else
      rc_targets+=("$rc")
      rc_plan_targets+=("$rc: remove codex-dev marker block")
    fi
  elif zshrc_has_any_codex_dev_marker "$rc"; then
    notes+=("Malformed zsh rc marker block will not be modified automatically; inspect manually: $rc")
  elif [[ -L "$rc" ]]; then
    notes+=("Symlinked zsh rc will not be modified: $rc")
  fi

  if command -v podman >/dev/null 2>&1; then
    ensure_podman_rootless
    need_cmd sha256sum
    while IFS= read -r name; do
      [[ -n "$name" ]] || continue
      cname="$(container_name "$name")"
      podman_exists_quietly container "$cname" && containers+=("$cname")
      if [[ "$remove_images" == "yes" ]]; then
        img="$(image_name "$name")"
        podman_exists_quietly image "$img" && images+=("$img")
      fi
      if [[ "$remove_volumes" == "yes" ]]; then
        for kind in home cache npm cargo gradle go; do
          vol="$(volume_name "$kind" "$name")"
          podman_exists_quietly volume "$vol" && volumes+=("$vol")
        done
      fi
    done < <(managed_project_names)
  else
    notes+=("Podman not found; no Podman resources were planned for removal.")
  fi

  printf '\n%s\n' "codex-dev uninstall plan"
  printf '%s\n' "Podman images:  $([[ "$remove_images" == "yes" ]] && printf remove || printf keep)"
  printf '%s\n' "Podman volumes: $([[ "$remove_volumes" == "yes" ]] && printf remove || printf keep)"
  print_plan_section "Files to remove:" "${file_targets[@]}"
  print_plan_section "Generated directories to remove:" "${generated_dir_targets[@]}"
  print_plan_section "Empty codex-dev directories to prune:" "${empty_dir_targets[@]}"
  print_plan_section "Zsh rc edits:" "${rc_plan_targets[@]}"
  print_plan_section "Podman containers to remove:" "${containers[@]}"
  print_plan_section "Podman images to remove:" "${images[@]}"
  print_plan_section "Podman volumes to remove:" "${volumes[@]}"
  print_plan_section "Notes:" "${notes[@]}"
  printf '%s\n' "Project directories and project .codex-dev metadata will be preserved."
  printf '\n'

  if ! prompt_yes_no "Proceed with uninstall?" no; then
    log "Uninstall aborted; no changes were made."
    return 0
  fi

  for cname in "${containers[@]}"; do
    podman rm -f "$cname" >/dev/null || die "Failed to remove container: $cname"
    log "Removed container: $cname"
  done
  for img in "${images[@]}"; do
    podman image rm -f "$img" >/dev/null || die "Failed to remove image: $img"
    log "Removed image: $img"
  done
  for vol in "${volumes[@]}"; do
    podman volume rm "$vol" >/dev/null || die "Failed to remove volume: $vol"
    log "Removed volume: $vol"
  done
  for rc in "${rc_targets[@]}"; do
    remove_codex_dev_zsh_marker "$rc"
  done
  for installed_bin in "${file_targets[@]}"; do
    rm -f -- "$installed_bin" || die "Failed to remove file: $installed_bin"
    log "Removed file: $installed_bin"
  done
  for data_dir in "${generated_dir_targets[@]}"; do
    rm -rf -- "$data_dir" || die "Failed to remove generated directory: $data_dir"
    log "Removed generated directory: $data_dir"
  done
  for data_dir in "${empty_dir_targets[@]}"; do
    if rmdir -- "$data_dir" 2>/dev/null; then
      log "Removed empty directory: $data_dir"
    else
      log "Directory not empty; preserved: $data_dir"
    fi
  done

  log "Uninstall complete. Project directories and project .codex-dev metadata were preserved."
}

doctor_cmd() {
  local name="${1:-}" rootless info img real cfg cname status kind vol effective_ro
  [[ $# -le 1 ]] || die "Usage: codex-dev doctor [project]"
  ensure_setup_dirs
  need_cmd podman
  need_cmd realpath
  need_cmd sha256sum
  need_cmd find
  validate_image_prefix
  printf 'codex-dev version: %s\n' "$VERSION"
  printf 'user: %s uid=%s gid=%s\n' "$(id -un)" "$(id -u)" "$(id -g)"
  [[ "$(id -u)" != "0" ]] || die "Do not run codex-dev as root. Use rootless Podman as your normal user."
  printf 'projects root: %s\n' "$PROJECTS_ROOT"
  ensure_projects_root_safe
  printf 'projects root symlink: no\n'
  info="$(podman info --format '{{.Host.Security.Rootless}}' 2>/dev/null || true)"
  rootless="unknown"
  [[ "$info" == "true" ]] && rootless="yes"
  [[ "$info" == "false" ]] && rootless="no"
  printf 'podman rootless: %s\n' "$rootless"
  [[ "$rootless" == "yes" ]] || die "Could not confirm rootless Podman. podman info reported rootless=$rootless."
  if command -v getenforce >/dev/null 2>&1; then
    printf 'SELinux: %s\n' "$(getenforce)"
  fi
  if [[ -n "$name" ]]; then
    require_project_name "$name"
    real="$(project_path_real "$name")"
    cfg="$(project_config_path "$name")"
    load_project_config "$name"
    img="$(image_name "$name")"
    cname="$(container_name "$name")"
    if [[ "$CFG_READ_ONLY_ROOT" == "yes" ]]; then effective_ro="yes"; else effective_ro="no"; fi
    printf 'project: %s\n' "$name"
    printf 'resource id: %s\n' "$(resource_id "$name")"
    printf 'project real path: %s\n' "$real"
    printf 'config: %s\n' "$cfg"
    printf 'profile: %s\n' "$CFG_PROFILE"
    printf 'read-only root by default: %s\n' "$effective_ro"
    printf 'build script: %s\n' "${CFG_BUILD_SCRIPT:-none}"
    printf 'image: %s\n' "$img"
    if podman image exists "$img"; then
      printf 'image exists: yes\n'
    else
      printf 'image exists: no\n'
    fi
    if podman container exists "$cname"; then
      status="$(podman inspect -f '{{.State.Status}}' "$cname" 2>/dev/null || printf 'unknown')"
      printf 'container exists: yes (%s)\n' "$status"
    else
      printf 'container exists: no\n'
    fi
    check_project_tree_safety "$name"
    if [[ "${CODEX_DEV_ALLOW_HARDLINKS:-0}" != "1" ]]; then
      printf 'project tree safety: sockets/fifos/devices=none nested-mounts=none hardlinks=none detected\n'
    else
      printf 'project tree safety: sockets/fifos/devices=none nested-mounts=none hardlink check bypassed\n'
    fi
    printf 'runtime mount policy: exactly one host bind mount: %s -> /workspace\n' "$real"
    printf 'project volume names:\n'
    for kind in home cache npm cargo gradle go; do
      vol="$(volume_name "$kind" "$name")"
      printf '  %-8s %s\n' "$kind" "$vol"
    done
    printf 'forbidden mounts: home=no Projects-parent=no ssh=no config=no podman-socket=no docker-socket=no host-devices=no\n'
    printf 'privileged: no\n'
    printf 'host pid/ipc/network: no\n'
    printf 'user namespace: keep-id\n'
    printf 'SELinux project label option: :Z\n'
  fi
  log "doctor OK"
}

main() {
  local cmd="${1:-}"
  shift || true
  case "$cmd" in
    -h|--help|help|""|profiles|completion|__complete) ;;
    *) require_not_root ;;
  esac
  case "$cmd" in
    setup) [[ $# -eq 0 ]] || die "Usage: codex-dev setup"; setup_cmd ;;
    init) init_cmd "$@" ;;
    profiles) [[ $# -eq 0 ]] || die "Usage: codex-dev profiles"; print_profiles ;;
    list) list_cmd "$@" ;;
    config) [[ $# -eq 1 ]] || die "Usage: codex-dev config <project>"; config_cmd "$1" ;;
    edit) [[ $# -eq 1 ]] || die "Usage: codex-dev edit <project>"; edit_cmd "$1" ;;
    edit-build-script) [[ $# -eq 1 ]] || die "Usage: codex-dev edit-build-script <project>"; edit_build_script_cmd "$1" ;;
    build) [[ $# -eq 1 ]] || die "Usage: codex-dev build <project>"; build_cmd "$1" ;;
    shell) [[ $# -ge 1 ]] || die "Usage: codex-dev shell <project> [--rw-root]"; shell_cmd "$@" ;;
    omx) [[ $# -ge 1 ]] || die "Usage: codex-dev omx <project> [--rw-root]"; omx_cmd "$@" ;;
    codex) [[ $# -ge 1 ]] || die "Usage: codex-dev codex <project> [--rw-root] [-- <extra codex args...>]"; codex_cmd "$@" ;;
    exec) [[ $# -ge 2 ]] || die "Usage: codex-dev exec <project> [--rw-root] -- <prompt>"; exec_cmd "$@" ;;
    attach) attach_cmd "$@" ;;
    doctor) doctor_cmd "$@" ;;
    volumes) [[ $# -eq 1 ]] || die "Usage: codex-dev volumes <project>"; volumes_cmd "$1" ;;
    reset-cache) [[ $# -eq 1 ]] || die "Usage: codex-dev reset-cache <project>"; reset_cache_cmd "$1" ;;
    reset-home) [[ $# -eq 1 ]] || die "Usage: codex-dev reset-home <project>"; reset_home_cmd "$1" ;;
    nuke-env) [[ $# -eq 1 ]] || die "Usage: codex-dev nuke-env <project>"; nuke_env_cmd "$1" ;;
    uninstall) uninstall_cmd "$@" ;;
    completion) completion_cmd "$@" ;;
    __complete) complete_cmd_internal "$@" ;;
    -h|--help|help|"") usage ;;
    *) usage; die "Unknown command: $cmd" ;;
  esac
}

main "$@"
